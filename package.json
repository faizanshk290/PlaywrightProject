{
  "name": "playwright-pom-typescript",
  "version": "1.0.0",
  "description": "Playwright Page Object Model framework with TypeScript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:chrome": "npx playwright test --project=chromium",
