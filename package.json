    "test:login": "npx playwright test tests/login-feature/",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report",
    "record": "npx tsx recorder/dom-recorder.ts",
    "record:url": "npx tsx recorder/dom-recorder.ts",
    "record:steps": "npx tsx recorder/step-recorder.ts"
  },
  "keywords": [
    "playwright",
    "typescript",
